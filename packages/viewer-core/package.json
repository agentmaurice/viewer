{
  "name": "@agent-maurice/viewer-core",
  "version": "0.1.0",
  "description": "Core runtime for the AgentMaurice universal viewer",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "generate:chatserver-schemas": "node ./scripts/generate-chatserver-schemas.mjs",
    "build": "npm run generate:chatserver-schemas && tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run generate:chatserver-schemas && tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "files": ["dist"],
  "license": "UNLICENSED"
}
